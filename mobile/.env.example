# ─── Supabase ──────────────────────────────────────────────
# Dùng CHUNG project Supabase với web app (cùng giá trị trong ../.env.local).
# Tiền tố EXPO_PUBLIC_ để Expo nhúng vào bundle client.
# Lưu ý: chỉ dùng anon key (KHÔNG bao giờ đưa service_role key vào app mobile).
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# URL của web app (dùng cho các API route lookup/translate ở feature sau).
EXPO_PUBLIC_API_BASE_URL=http://localhost:3000
