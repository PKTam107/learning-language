# ─── Supabase ──────────────────────────────────────────────
# Dùng CHUNG project Supabase với web app (cùng giá trị trong ../.env.local).
# Tiền tố EXPO_PUBLIC_ để Expo nhúng vào bundle client.
# Lưu ý: chỉ dùng anon key (KHÔNG bao giờ đưa service_role key vào app mobile).
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# URL của web app (dùng cho các API route lookup/translate).
#   • Android emulator: http://10.0.2.2:3000  (alias trỏ về máy host)
#   • Điện thoại thật:  http://<IP-LAN-máy-chạy-web>:3000  (vd 192.168.1.x)
#   • Web đã deploy:    https://<domain>          (vd Vercel)
# ⚠️ Nếu web chạy trong WSL2: script `dev` ở repo gốc phải là `next dev -H 0.0.0.0`
#    (bind IPv4) — nếu không, emulator gọi 10.0.2.2:3000 sẽ bị refused.
EXPO_PUBLIC_API_BASE_URL=http://10.0.2.2:3000
