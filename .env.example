# ─── Supabase ──────────────────────────────────────────────
# Lấy ở: Supabase Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# Service role key — CHỈ dùng ở server (route handlers). KHÔNG để lộ ra client.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ─── AI / Translate ───────────────────────────────────────
# Chọn nhà cung cấp dịch: "mymemory" | "openai" | "gemini" | "libretranslate"
AI_PROVIDER=mymemory
# MyMemory: free, KHÔNG cần key. Thêm email hợp lệ để tăng quota ~5k→50k từ/ngày.
MYMEMORY_EMAIL=
# Điền key tương ứng với provider đã chọn (để trống = bỏ qua dịch, app vẫn chạy)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash
# LibreTranslate: self-host (docker) thì để localhost; instance công khai cần api_key
LIBRETRANSLATE_URL=http://localhost:5000
LIBRETRANSLATE_API_KEY=

# ─── App ──────────────────────────────────────────────────
# Dùng cho redirect OAuth (dev: http://localhost:3000)
NEXT_PUBLIC_SITE_URL=http://localhost:3000
